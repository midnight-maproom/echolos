      FadeOutSeconds: 0
    - ImagePath: Images/scene_balduin_castle
      FallbackImagePath: 
      NarrationText: "\u5E1D\u56FD\u8ECD\u306E\u8972\u6765\u306E\u77E5\u3089\u305B\u3092\u805E\u3044\u305F\u30D0\u30EB\u30C9\u30A5\u30A4\u30F3\u306F\u6226\u3048\u308B\u3082\u306E\u3092\u7D50\u96C6\u3057\u3001\u5E02\u6C11\u3092\u7826\u306B\u96C6\u3081\u3066\u7C60\u57CE\u3059\u308B\u3053\u3068\u3092\u6C7A\u610F\u3059\u308B\u3002\n\n\u305D\u3093\u306A\u5F7C\u3089\u306B\u6551\u3044\u306E\u624B\u306F\u3042\u308B\u306E\u3060\u308D\u3046\u304B\u3002"
