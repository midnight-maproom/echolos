      FallbackImagePath: 
      NarrationText: "\u3053\u306E\u58F0\u306F\u3002\u805E\u304D\u9593\u9055\u3046\u306F\u305A\u3082\u306A\u3044\u3002\n\n\u3042\u306E\u6642\u805E\u3044\u305F\u306E\u3068\u540C\u3058\u3001\u5927\u5207\u306A\u4EBA\u306E\u58F0\u3060\u3002"
      FadeInSeconds: 0
