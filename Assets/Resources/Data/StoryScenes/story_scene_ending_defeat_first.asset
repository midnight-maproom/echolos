  _definition:
    Id: ending_defeat_first
    Name: "A-b1 1 \u5468\u76EE\u30D0\u30C3\u30C9\u30A8\u30F3\u30C9 \u30EB\u30FC\u30D7\u306E\u958B\u59CB"
    Pages:
    - ImagePath: 
      FallbackImagePath: 
      NarrationText: "\u738B\u56FD\u8ECD\u306F\u61F8\u547D\u306B\u6226\u3063\u305F\u304C\u9632\u885B\u7DDA\u3092\u7834\u3089\u308C\u3001\u3064\u3044\u306B\u738B\u57CE\u3078\u6575\u306E\u4FB5\u5165\u3092\u8A31\u3057\u3066\u3057\u307E\u3046\u3002\n\n\u738B\u5973\u306F\u3042\u306A\u305F\u306E\u624B\u3092\u5F15\u304D\u3001\u738B\u57CE\u306E\u5965\u3078\u3068\u5411\u304B\u3046\u3002 "
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_temple
      FallbackImagePath: 
      NarrationText: "\u3053\u3053\u306F\u3001\u521D\u3081\u3066\u738B\u5973\u3068\u51FA\u4F1A\u3063\u305F\u5834\u6240\u3002"
      FadeInSeconds: 0.8
      DisplaySeconds: 0
      FadeOutSeconds: 0
    - ImagePath: Images/scene_temple
      FallbackImagePath: 
      NarrationText: "\u300C\u3042\u306A\u305F\u306F\u3001\u3082\u3068\u306E\u5834\u6240\u306B\u5E30\u308B\u3079\u304D\u3060\u308F\u300D\n\n\u738B\u5973\u306F\u8056\u5263\u3092\u69CB\u3048\u3001\u76EE\u3092\u9589\u3058\u308B\u3002\n\u4F55\u304B\u8A00\u304A\u3046\u3068\u3059\u308B\u3042\u306A\u305F\u3002\u3060\u304C\u3001\u8A00\u8449\u306B\u306A\u3089\u306A\u3044\u3002"
      FadeInSeconds: 0
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_ending_send_back
      FallbackImagePath: 
      NarrationText: "\u3084\u304C\u3066\u9B54\u6CD5\u9663\u304C\u73FE\u308C\u3001\u795E\u6BBF\u306F\u5149\u306B\u5305\u307E\u308C\u308B\u3002\n\n\u3042\u306A\u305F\u306F\u3068\u3063\u3055\u306B\u738B\u5973\u3078\u624B\u3092\u4F38\u3070\u3059\u304C\u2015"
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0
    - ImagePath: Images/scene_ending_send_back
      FallbackImagePath: 
      NarrationText: " \u300C\u2015\u3042\u308A\u304C\u3068\u3046\u3002\u300D "
      FadeInSeconds: 0
      DisplaySeconds: 0
      FadeOutSeconds: 0
    - ImagePath: Images/scene_ending_send_back
      FallbackImagePath: 
      NarrationText: "\u6C17\u4E08\u306B\u7B11\u3046\u738B\u5973\u306E\u59FF\u304C\u3001\u5149\u306E\u4E2D\u306B\u6D88\u3048\u3066\u3044\u304F\u3002"
      FadeInSeconds: 0
      DisplaySeconds: 0
      FadeOutSeconds: 1.5
    - ImagePath: Images/VSPrototype/meta_hub_background
      FallbackImagePath: 
      NarrationText: "\u2015\u6C17\u304C\u4ED8\u304F\u3068\u3001\u795E\u6BBF\u306F\u8DE1\u5F62\u3082\u306A\u304F\u306A\u3063\u3066\u3044\u305F\u3002\n\u3042\u308B\u306E\u306F\u3001\u82D4\u3080\u3057\u305F\u304C\u308C\u304D\u306E\u5C71\u3068\u8349\u6728\u3060\u3051\u3002\n\n\u3082\u3068\u306E\u4E16\u754C\u306B\u623B\u3063\u305F\u306E\u3060\u3068\u7406\u89E3\u3057\u3001\u3072\u3056\u307E\u305A\u304F\u3042\u306A\u305F\u3002\n\u7121\u529B\u611F\u306B\u3055\u3044\u306A\u307E\u308C\u3066\u3044\u308B\u3068\u3001\u304B\u3059\u304B\u306B\u58F0\u304C\u805E\u3053\u3048\u308B\u3002"
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0
