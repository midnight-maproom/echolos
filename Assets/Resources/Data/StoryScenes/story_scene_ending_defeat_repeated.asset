    Pages:
    - ImagePath: 
      FallbackImagePath: 
      NarrationText: "\u4F55\u304C\u30C0\u30E1\u3060\u3063\u305F\u306E\u304B\u3002\n\u738B\u5973\u306B\u624B\u3092\u5F15\u304B\u308C\u306A\u304C\u3089\u8003\u3048\u308B\u3042\u306A\u305F\u3002\n\n\u307E\u305F\u3001\u3044\u3064\u3082\u306E\u3042\u306E\u5834\u6240\u3078\u5411\u304B\u3046\u3002"
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_temple
      FallbackImagePath: 
      NarrationText: "\u300C\u3042\u306A\u305F\u306F\u3001\u3082\u3068\u306E\u5834\u6240\u306B\u5E30\u308B\u3079\u304D\u3060\u308F\u300D\n\n\u738B\u5973\u306F\u8056\u5263\u3092\u69CB\u3048\u3001\u76EE\u3092\u9589\u3058\u308B\u3002\n\n\u4F55\u3092\u8A00\u3063\u3066\u3082\u3001\u4ECA\u66F4\u9045\u3044\u3068\u308F\u304B\u3063\u3066\u3044\u305F\u3002"
      FadeInSeconds: 0.8
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_temple
      FallbackImagePath: 
      NarrationText: "\u3084\u304C\u3066\u9B54\u6CD5\u9663\u304C\u73FE\u308C\u3001\u795E\u6BBF\u306F\u5149\u306B\u5305\u307E\u308C\u308B\u3002\n\u3042\u306A\u305F\u306F\u3058\u3063\u3068\u3001\u738B\u5973\u306E\u76EE\u3092\u898B\u3064\u3081\u308B\u3002"
      FadeInSeconds: 0.8
      DisplaySeconds: 0
      FadeOutSeconds: 0.8
    - ImagePath: Images/scene_ending_send_back
      FallbackImagePath: 
      NarrationText: "\u300C\u3042\u308A\u304C\u3068\u3046\u3002\u300D\n\n\u6C17\u4E08\u306B\u7B11\u3046\u738B\u5973\u306E\u59FF\u304C\u3001\u5149\u306E\u4E2D\u3078\u6D88\u3048\u3066\u3044\u304F\u3002"
