      FadeOutSeconds: 1
    - ImagePath: Images/VSPrototype/meta_hub_background
      FallbackImagePath: 
      NarrationText: "\u2015\u6C17\u304C\u4ED8\u304F\u3068\u3001\u898B\u6163\u308C\u305F\u304C\u308C\u304D\u306E\u5C71\u306E\u524D\u306B\u7ACB\u3063\u3066\u3044\u308B\u3042\u306A\u305F\u3002\n\u3059\u3067\u306B\u3001\u899A\u609F\u306F\u6C7A\u307E\u3063\u3066\u3044\u308B\u3002\n\n\u8033\u3092\u6F84\u307E\u3057\u3001\u58F0\u306E\u3059\u308B\u307B\u3046\u3078\u6B69\u304D\u59CB\u3081\u305F\u3002"
