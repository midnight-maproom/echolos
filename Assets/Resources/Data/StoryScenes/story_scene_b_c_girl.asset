  _definition:
    Id: b_c_girl
    Name: "B-c \u8B0E\u306E\u5C11\u5973"
    Pages:
    - ImagePath: 
      FallbackImagePath: 
      NarrationText: "\u5E1D\u56FD\u8ECD\u3068\u306E\u6C7A\u6226\u306B\u5411\u3051\u3066\u3001\u738B\u5973\u306F\u6C11\u3084\u5175\u3092\u9F13\u821E\u3059\u308B\u305F\u3081\u3001\u738B\u90FD\u3067\u6F14\u8AAC\u3092\u884C\u3063\u3066\u3044\u305F\u3002\n"
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_mysterious_girl
      FallbackImagePath: 
      NarrationText: "\u305D\u306E\u59FF\u3092\u9060\u76EE\u304B\u3089\u898B\u308B\u8D64\u9AEA\u306E\u5C11\u5973\u3002\n\u5C11\u5973\u306B\u4F3C\u3064\u304B\u308F\u3057\u304F\u306A\u3044\u5927\u5263\u3092\u80CC\u8CA0\u3063\u3066\u3001\u7F8E\u3057\u3044\u30DA\u30F3\u30C0\u30F3\u30C8\u3092\u9996\u306B\u304B\u3051\u3066\u3044\u308B\u3002"
      FadeInSeconds: 0.6
      DisplaySeconds: 0
      FadeOutSeconds: 0
    - ImagePath: Images/scene_mysterious_girl
      FallbackImagePath: 
      NarrationText: "\u738B\u5973\u306E\u6F14\u8AAC\u3092\u805E\u3044\u3066\u3044\u308B\u306E\u304B\u805E\u3044\u3066\u3044\u306A\u3044\u306E\u304B\u3001\u6012\u308A\u3068\u3082\u60B2\u3057\u307F\u3068\u3082\u3068\u308C\u308B\u8868\u60C5\u3067\u3058\u3063\u3068\u898B\u3064\u3081\u308B\u3002\n\n\u738B\u5973\u306F\u5F7C\u5973\u306B\u6C17\u3065\u304F\u3053\u3068\u3082\u306A\u304F\u3001\u6F14\u8AAC\u3092\u7D9A\u3051\u3066\u3044\u308B\u3002"
      FadeInSeconds: 0
      DisplaySeconds: 0
      FadeOutSeconds: 0
    - ImagePath: Images/scene_mysterious_girl
      FallbackImagePath: 
      NarrationText: "\u4F55\u3082\u8A00\u308F\u305A\u3001\u8E35\u3092\u8FD4\u3059\u5C11\u5973\u3002\u5F7C\u5973\u304C\u738B\u56FD\u306B\u623B\u308B\u3053\u3068\u306F\u306A\u304B\u3063\u305F\u3002"
      FadeInSeconds: 0
