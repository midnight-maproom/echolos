    Name: "B-d \u6551\u63F4\u6210\u529F\uFF08\u30D0\u30EB\u30C9\u30A5\u30A4\u30F3\u304B\u3089\u8A17\u3059\uFF09"
    Pages:
    - ImagePath: 
      FallbackImagePath: 
      NarrationText: "\u596A\u9084\u3057\u305F\u7826\u3092\u8A2A\u308C\u305F\u738B\u5973\u306B\u8B01\u898B\u3059\u308B\u30D0\u30EB\u30C9\u30A5\u30A4\u30F3\u3002\n\u4F53\u306F\u50B7\u3060\u3089\u3051\u3067\u6B69\u304F\u3053\u3068\u3082\u3067\u304D\u306A\u3044\u304C\u3001\u76EE\u306B\u306F\u529B\u5F37\u3055\u304C\u6B8B\u3063\u3066\u3044\u308B\u3002\n\n\u300C\u738B\u5973\u3088\u3001\u5FC5\u305A\u3084\u6765\u3066\u3044\u305F\u3060\u3051\u308B\u3068\u3001\u4FE1\u3058\u3066\u304A\u308A\u307E\u3057\u305F\u300D"
      FadeInSeconds: 1
      DisplaySeconds: 0
      FadeOutSeconds: 0.6
    - ImagePath: Images/scene_balduin_bestow
      FallbackImagePath: 
      NarrationText: "\u8D64\u9AEA\u306E\u5C11\u5973\u304C\u73FE\u308C\u3001\u819D\u3092\u3064\u304F\u3002\n\n\u300C\u308F\u3057\u306F\u3082\u3046\u6226\u3048\u307E\u305B\u3093\u304C\u3001\u3069\u3046\u304B\u3053\u306E\u30D6\u30EA\u30B8\u30C3\u30C8\u3092\u304A\u9023\u308C\u304F\u3060\u3055\u3044\u307E\u305B\u3002\u300D"
